<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Absensi Santri - AL-HADI</title>
    
    <!-- CSS Wajib Layout & Komponen -->
    <link rel="stylesheet" href="css/style-base.css">
    <link rel="stylesheet" href="css/style-layout.css">
    <link rel="stylesheet" href="css/style-components.css">
    
    <!-- CSS Khusus Halaman Absensi -->
    <link rel="stylesheet" href="css/style-absensi.css">

    <script src="https://unpkg.com/lucide@latest"></script>
</head>
<body class="dark">

    <div id="layout-wrapper"></div>

    <template id="page-content">
        <div class="absensi-page-container">
            
            <!-- TOOLBAR UTAMA -->
            <div class="page-toolbar">
                <div class="toolbar-info">
                    <button id="btn-back-kelas" class="btn-back hidden" onclick="goBackToKelasList()">
                        <i data-lucide="arrow-left"></i>
                        <span>Kembali ke Daftar Kelas</span>
                    </button>
                    <h2 class="page-title" id="page-title">Absensi Santri</h2>
                    <p class="page-subtitle" id="page-subtitle">Pilih kelas untuk mengelola kehadiran santri harian.</p>
                </div>

                <!-- SELECTOR PERIODE IMTIHAN -->
                <div class="imtihan-selector-wrapper">
                    <label for="select-imtihan"><i data-lucide="award"></i> Periode:</label>
                    <select id="select-imtihan" class="form-input-sm" onchange="changeImtihanPeriod(this.value)">
                        <option value="Imtihan 1">Imtihan 1 (Semester Ganjil)</option>
                        <option value="Imtihan 2">Imtihan 2 (Semester Genap)</option>
                    </select>
                </div>
            </div>

            <!-- AREA KONTEN UTAMA -->
            <div class="absensi-content-card">
                
                <!-- VIEW 1: DAFTAR KELAS -->
                <div id="view-kelas">
                    <div id="empty-state-kelas" class="empty-state">
                        <div class="empty-icon-wrapper">
                            <i data-lucide="school"></i>
                        </div>
                        <h3 class="empty-title">Belum Ada Data Kelas</h3>
                        <p class="empty-desc">Tambahkan kelas terlebih dahulu pada menu Data Santri untuk mulai melakukan absensi.</p>
                    </div>

                    <div id="kelas-grid-container" class="kelas-grid hidden">
                        <!-- Card kelas dimuat via JS -->
                    </div>
                </div>

                <!-- VIEW 2: LIST ABSENSI SANTRI -->
                <div id="view-absensi" class="hidden">
                    
                    <!-- BOX PANDUAN ABSENSI -->
                    <div class="absensi-guide-box">
                        <div class="guide-icon">
                            <i data-lucide="info"></i>
                        </div>
                        <div class="guide-text">
                            <strong>Panduan Absensi:</strong>
                            <p>Klik pada nama santri untuk mengubah status (Hadir, Izin, Sakit, Alpa). Secara default semua santri di-set <b>Hadir</b>. Jangan lupa klik tombol <b>Simpan Absensi Hari Ini</b> di bawah setelah selesai.</p>
                        </div>
                    </div>

                    <!-- LIST SANTRI -->
                    <div id="santri-absensi-container" class="absensi-list-grid">
                        <!-- List santri dimuat via JS -->
                    </div>

                    <!-- BOTTOM BAR SIMPAN ABSENSI HARI INI -->
                    <div class="absensi-bottom-bar">
                        <div class="today-date-info">
                            <i data-lucide="calendar"></i>
                            <span id="today-date-text">Rabu, 24 Juli 2026</span>
                        </div>
                        <button class="btn-primary btn-save-absensi" onclick="saveTodayAbsensi()">
                            <i data-lucide="check-circle-2"></i>
                            <span>Simpan Absensi Hari Ini</span>
                        </button>
                    </div>

                </div>

            </div>

        </div>

        <!-- MODAL PILIH STATUS ABSENSI -->
        <div id="modal-status-absensi" class="modal-overlay">
            <div class="modal-card modal-sm">
                <div class="modal-header">
                    <div class="modal-header-title">
                        <i data-lucide="user-check" class="modal-header-icon"></i>
                        <h3>Ubah Status Absensi</h3>
                    </div>
                    <button class="btn-close-modal" onclick="closeModalStatus()">
                        <i data-lucide="x"></i>
                    </button>
                </div>

                <div class="modal-body">
                    <div class="target-santri-info">
                        <h4 id="modal-santri-nama">Nama Santri</h4>
                        <span id="modal-tanggal-text" class="text-date-badge">Rabu, 24 Juli 2026</span>
                    </div>

                    <!-- PILIHAN STATUS (CARDS) -->
                    <div class="status-options-grid">
                        <label class="status-option-card option-hadir">
                            <input type="radio" name="status-kehadiran" value="hadir">
                            <div class="status-card-body">
                                <i data-lucide="check-circle"></i>
                                <span>Hadir (Masuk)</span>
                            </div>
                        </label>

                        <label class="status-option-card option-izin">
                            <input type="radio" name="status-kehadiran" value="izin">
                            <div class="status-card-body">
                                <i data-lucide="file-text"></i>
                                <span>Izin</span>
                            </div>
                        </label>

                        <label class="status-option-card option-sakit">
                            <input type="radio" name="status-kehadiran" value="sakit">
                            <div class="status-card-body">
                                <i data-lucide="activity"></i>
                                <span>Sakit</span>
                            </div>
                        </label>

                        <label class="status-option-card option-alpa">
                            <input type="radio" name="status-kehadiran" value="alpa">
                            <div class="status-card-body">
                                <i data-lucide="x-circle"></i>
                                <span>Alpa (Tanpa Ket.)</span>
                            </div>
                        </label>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-cancel" onclick="closeModalStatus()">Batal</button>
                    <button type="button" class="btn btn-save-active" onclick="applySantriStatusChange()">Pilih & Simpan</button>
                </div>
            </div>
        </div>

    </template>

    <script src="js/main.js"></script>
    <script type="module" src="js/absensi.js"></script>

</body>
</html>
