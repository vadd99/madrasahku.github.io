/* Tambahan CSS khusus Rekap Nilai */

.btn-tambah-uh {
    background: transparent;
    color: #10b981;
    border: 1px dashed #10b981;
    padding: 10px;
    width: 100%;
    border-radius: var(--radius-sm, 6px);
    cursor: pointer;
    font-weight: 600;
    margin-top: 15px;
    transition: all 0.2s ease;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 8px;
}

.btn-tambah-uh:hover {
    background: rgba(16, 185, 129, 0.1);
}

.btn-primary {
    background-color: #10b981;
    color: white;
    border: none;
    cursor: pointer;
    transition: 0.2s;
}

.btn-primary:hover {
    background-color: #059669;
}

.badge-status-empty { 
    background: rgba(255, 255, 255, 0.06); 
    color: var(--text-muted); 
    border: 1px dashed var(--border-color); 
}

/* === PERBAIKAN LAYOUT SELECTOR (PERIODE & MAPEL ATAS BAWAH) === */
.selectors-container {
    display: flex;
    flex-direction: column !important; 
    gap: 8px !important; /* Diperkecil agar lebih padat */
    width: 100%;
    margin-top: 0 !important; 
    margin-bottom: 16px; /* Jarak ke list santri */
}

.imtihan-selector-wrapper {
    display: flex;
    align-items: center;
    width: 100%; 
    box-sizing: border-box;
    gap: 10px;
    margin-top: 0;
}

.imtihan-selector-wrapper label {
    display: flex;
    align-items: center;
    gap: 6px;
    margin: 0;
    min-width: 80px; 
    font-weight: 600;
    color: var(--text-main);
}

.imtihan-selector-wrapper select {
    flex: 1; 
    width: 100%;
    padding: 6px 10px; /* Ukuran input diperkecil tingginya */
}

/* === TOMBOL TAMBAH MAPEL BIAR MENYALA DI DARK MODE === */
.btn-add-mapel {
    background-color: #10b981 !important;
    color: #ffffff !important;
    border: none;
    padding: 6px 12px !important; /* Ukuran diseimbangkan dengan select */
    border-radius: 6px;
    font-size: 0.85rem;
    font-weight: 700;
    white-space: nowrap;
    cursor: pointer;
    transition: 0.2s;
    box-shadow: 0 2px 10px rgba(16, 185, 129, 0.4); 
}

.btn-add-mapel:hover {
    background-color: #059669 !important;
    box-shadow: 0 2px 10px rgba(16, 185, 129, 0.6);
}

/* === TOMBOL CLOSE UNTUK PANDUAN PENILAIAN === */
.absensi-guide-box {
    position: relative;
    padding-right: 40px; 
}

.btn-close-guide {
    position: absolute;
    top: 12px;
    right: 12px;
    background: transparent;
    border: none;
    color: var(--text-muted);
    cursor: pointer;
    padding: 4px;
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: 0.2s;
}

.btn-close-guide:hover {
    background: rgba(239, 68, 68, 0.15); 
    color: #ef4444;
}

/* === PERBAIKAN TAMPILAN REKAP NILAI (MINI BADGES) === */
.nilai-badge-container {
    display: flex;
    flex-wrap: wrap; 
    gap: 4px;
    justify-content: flex-start; 
    max-width: 180px; 
}

.nilai-mini-badge {
    background: rgba(16, 185, 129, 0.15); 
    color: #10b981; 
    border: 1px solid rgba(16, 185, 129, 0.3);
    padding: 2px 6px;
    border-radius: 4px;
    font-size: 0.65rem;
    white-space: nowrap; 
}

/* === STYLING HEADER "REKAP NILAI" BIAR LEBIH SLIM === */
.page-header-card {
    background: linear-gradient(145deg, rgba(16, 185, 129, 0.08) 0%, rgba(0, 0, 0, 0.2) 100%);
    border: 1px solid rgba(16, 185, 129, 0.2);
    border-radius: 10px;
    padding: 12px; /* Padat */
    margin-bottom: 12px; 
    position: relative;
    overflow: hidden;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
}

.page-header-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 3px;
    background: linear-gradient(90deg, #10b981, transparent);
    opacity: 0.9;
}

.header-content-flex {
    display: flex;
    align-items: center;
    gap: 12px; /* Jarak lebih rapat */
}

/* Kotak ikon bernuansa hijau */
.header-icon-wrapper {
    background: rgba(16, 185, 129, 0.15);
    color: #10b981;
    width: 38px; /* Diperkecil */
    height: 38px;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    border: 1px solid rgba(16, 185, 129, 0.3);
}

.header-icon-wrapper i {
    width: 20px;
    height: 20px;
}

/* Merapikan teks judul dan subjudul */
.header-text-wrapper .page-title {
    font-size: 1.1rem; /* Diperkecil */
    font-weight: 700;
    color: #ffffff;
    margin: 0 0 2px 0;
}

.header-text-wrapper .page-subtitle {
    font-size: 0.75rem; /* Diperkecil */
    color: var(--text-muted, #94a3b8);
    margin: 0;
    line-height: 1.3;
}

/* === PERBAIKAN TOMBOL BACK JADI IKON MINIMALIS === */
#btn-back-kelas {
    background: rgba(16, 185, 129, 0.15); 
    color: #10b981;
    border: 1px solid rgba(16, 185, 129, 0.3);
    width: 38px;
    height: 38px;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    margin: 0; 
    cursor: pointer;
    transition: all 0.2s;
    flex-shrink: 0;
}

#btn-back-kelas:hover {
    background: #10b981;
    color: #ffffff;
}

#btn-back-kelas i {
    width: 20px;
    height: 20px;
}
