/* Tambahan CSS khusus Rekap Nilai */

.btn-tambah-uh {
    background: transparent;
    color: #10b981;
    border: 1px dashed #10b981;
    padding: 10px;
    width: 100%;
    border-radius: var(--radius-sm, 6px);
    cursor: pointer;
    font-weight: 600;
    margin-top: 15px;
    transition: all 0.2s ease;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 8px;
}

.btn-tambah-uh:hover {
    background: rgba(16, 185, 129, 0.1);
}

.btn-primary {
    background-color: #10b981;
    color: white;
    border: none;
    cursor: pointer;
    transition: 0.2s;
}

.btn-primary:hover {
    background-color: #059669;
}

.badge-status-empty { 
    background: rgba(255, 255, 255, 0.06); 
    color: var(--text-muted); 
    border: 1px dashed var(--border-color); 
}

/* === PERBAIKAN LAYOUT SELECTOR (PERIODE & MAPEL) BIAR SEJAJAR & RATA KANAN === */
.selectors-container {
    display: flex;
    flex-direction: column; /* Ditumpuk atas bawah */
    gap: 12px;
    width: 100%;
    margin-top: 16px;
}

.selectors-container .imtihan-selector-wrapper {
    display: flex;
    align-items: center;
    width: 100%; /* Memaksa lebar penuh agar tepi kanannya sejajar */
    box-sizing: border-box;
    gap: 10px;
    margin-top: 0;
}

.selectors-container .imtihan-selector-wrapper label {
    display: flex;
    align-items: center;
    gap: 6px;
    margin: 0;
    min-width: 80px; /* Supaya lebar teks label "Periode" dan "Mapel" sama rata vertikal */
    font-weight: 600;
}

.selectors-container .imtihan-selector-wrapper select {
    flex: 1; /* Memaksa select mengisi penuh sisa ruang yang tersedia */
    width: 100%;
}

/* === TOMBOL CLOSE UNTUK PANDUAN PENILAIAN === */
.absensi-guide-box {
    position: relative;
    padding-right: 40px; /* Beri ruang di kanan agar text tidak tertimpa tombol X */
}

.btn-close-guide {
    position: absolute;
    top: 12px;
    right: 12px;
    background: transparent;
    border: none;
    color: var(--text-muted);
    cursor: pointer;
    padding: 4px;
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: 0.2s;
}

.btn-close-guide:hover {
    background: rgba(239, 68, 68, 0.15); /* Efek merah transparan saat di-hover */
    color: #ef4444;
}
