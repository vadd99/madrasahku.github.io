/* Layout Container Santri */
.santri-page-container {
    display: flex;
    flex-direction: column;
    gap: 16px;
    height: 100%;
}

.page-toolbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
}

.toolbar-info {
    display: flex;
    flex-direction: column;
    gap: 4px;
}

.btn-back {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--primary-text);
    font-size: 0.8rem;
    font-weight: 600;
    margin-bottom: 4px;
    cursor: pointer;
    background: none;
    border: none;
    width: fit-content;
    padding: 0;
}

.btn-back i {
    width: 16px;
    height: 16px;
}

.btn-back:hover {
    text-decoration: underline;
}

.page-title {
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--text-main);
}

.page-subtitle {
    font-size: 0.78rem;
    color: var(--text-muted);
}

/* Button Primary */
.btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--accent-gradient);
    color: #030712;
    font-weight: 700;
    font-size: 0.82rem;
    padding: 9px 16px;
    border-radius: var(--radius-md);
    box-shadow: 0 4px 12px rgba(16, 185, 129, 0.2);
    cursor: pointer;
    border: none;
}

.btn-icon {
    width: 16px;
    height: 16px;
}

.santri-content-card {
    background-color: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    flex: 1;
    padding: 16px;
    overflow-y: auto;
}

/* Empty State */
.empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 40px 16px;
    text-align: center;
}

.empty-icon-wrapper {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background-color: var(--primary-light);
    border: 1px solid var(--primary-border);
    color: var(--primary-text);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 12px;
}

.empty-title {
    font-size: 1rem;
    font-weight: 700;
    color: var(--text-main);
    margin-bottom: 4px;
}

.empty-desc {
    font-size: 0.8rem;
    color: var(--text-muted);
    max-width: 320px;
    margin-bottom: 16px;
}

.btn-primary-outline {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background-color: transparent;
    color: var(--primary-text);
    border: 1px solid var(--primary-border);
    padding: 8px 14px;
    border-radius: var(--radius-md);
    font-weight: 600;
    font-size: 0.8rem;
    cursor: pointer;
}

/* Grid Card Kelas */
.kelas-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 12px;
}

.kelas-card-item {
    background-color: var(--bg-sidebar);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    padding: 14px 16px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    cursor: pointer;
    transition: var(--transition);
}

.kelas-card-item:hover {
    border-color: var(--primary-border);
    transform: translateY(-2px);
    background-color: var(--primary-light);
}

.kelas-info {
    display: flex;
    flex-direction: column;
    gap: 3px;
    text-align: left;
}

.kelas-name {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--text-main);
}

.kelas-count {
    font-size: 0.78rem;
    color: var(--text-muted);
}

/* ===================================================
   HEADER DETAIL KELAS & STATISTIK COMPACT
   =================================================== */
.detail-kelas-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding-bottom: 10px;
    border-bottom: 1px solid var(--border-color);
    margin-bottom: 12px;
}

.sub-kelas-title {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--text-main);
}

.kelas-action-buttons {
    display: flex;
    align-items: center;
    gap: 6px;
}

.btn-action-sm {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 12px;
    font-size: 0.78rem;
    font-weight: 600;
    border-radius: 6px;
    cursor: pointer;
    border: 1px solid transparent;
    transition: var(--transition);
}

.btn-action-sm i {
    width: 14px;
    height: 14px;
}

.btn-edit-kelas {
    background-color: rgba(59, 130, 246, 0.12);
    color: #60a5fa;
    border-color: rgba(59, 130, 246, 0.25);
}

.btn-edit-kelas:hover {
    background-color: rgba(59, 130, 246, 0.22);
}

.btn-delete-kelas {
    background-color: rgba(239, 68, 68, 0.12);
    color: #f87171;
    border-color: rgba(239, 68, 68, 0.25);
}

.btn-delete-kelas:hover {
    background-color: rgba(239, 68, 68, 0.22);
}

/* Stat Strip Container */
.stat-strip-container {
    display: grid;
    grid-template-columns: 1.2fr repeat(3, 1fr);
    gap: 8px;
    margin-bottom: 16px;
}

@media (max-width: 600px) {
    .stat-strip-container {
        grid-template-columns: 1fr 1fr;
    }
    .stat-wali {
        grid-column: span 2;
    }
}

.stat-pill-card {
    background: var(--bg-sidebar);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    padding: 8px 12px;
    display: flex;
    align-items: center;
    gap: 10px;
}

.stat-pill-icon {
    width: 32px;
    height: 32px;
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
}

.stat-pill-icon i,
.stat-pill-icon svg {
    width: 16px;
    height: 16px;
}

.stat-pill-content {
    display: flex;
    flex-direction: column;
    text-align: left;
    overflow: hidden;
}

.stat-pill-label {
    font-size: 0.68rem;
    color: var(--text-muted);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.3px;
}

.stat-pill-value {
    font-size: 0.88rem;
    font-weight: 700;
    color: var(--text-main);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

/* Variasi Warna Stat Pill */
.stat-wali .stat-pill-icon {
    background: rgba(148, 163, 184, 0.12);
    color: #cbd5e1;
}

.stat-total .stat-pill-icon {
    background: rgba(16, 185, 129, 0.12);
    color: #10b981;
}

.stat-male .stat-pill-icon {
    background: rgba(59, 130, 246, 0.12);
    color: #3b82f6;
}

.stat-female .stat-pill-icon {
    background: rgba(236, 72, 153, 0.12);
    color: #ec4899;
}

/* List Santri (Sub-Menu) */
.santri-list {
    display: flex;
    flex-direction: column;
    gap: 8px;
}

.santri-item {
    background-color: var(--bg-sidebar);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    padding: 12px 14px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    cursor: pointer;
    transition: var(--transition);
}

.santri-item:hover {
    border-color: var(--primary-border);
    background-color: var(--primary-light);
}

.santri-item-left {
    display: flex;
    align-items: center;
    gap: 12px;
}

.number-badge {
    width: 32px;
    height: 32px;
    border-radius: 8px;
    background-color: var(--primary-light);
    color: var(--primary-text);
    border: 1px solid var(--primary-border);
    font-size: 0.82rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
}

.santri-item-name {
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--text-main);
    text-align: left;
}

.santri-item-sub {
    font-size: 0.73rem;
    color: var(--text-muted);
    text-align: left;
}

.chevron-icon {
    width: 18px;
    height: 18px;
    color: var(--text-light);
    flex-shrink: 0;
}

/* Modal Form Note & Always Active Button */
.form-note {
    font-size: 0.72rem;
    color: var(--primary-text);
    background-color: var(--primary-light);
    padding: 8px 10px;
    border-radius: var(--radius-sm);
    margin-bottom: 12px;
    border: 1px solid var(--primary-border);
}

.btn-save-active {
    background: var(--accent-gradient);
    color: #030712;
    font-weight: 700;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 9px 18px;
    border-radius: var(--radius-md);
    transition: var(--transition);
    cursor: pointer;
    box-shadow: 0 4px 12px rgba(16, 185, 129, 0.25);
    border: none;
}

.btn-save-active:hover {
    transform: translateY(-1px);
    box-shadow: 0 6px 16px rgba(16, 185, 129, 0.35);
}

/* Modal Core Styles */
.modal-card {
    background-color: var(--bg-sidebar);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    width: 100%;
    max-width: 440px;
    box-shadow: var(--shadow-lg);
}

.modal-header {
    padding: 14px 18px;
    border-bottom: 1px solid var(--border-color);
    display: flex;
    align-items: center;
    justify-content: space-between;
}

.modal-header-title {
    display: flex;
    align-items: center;
    gap: 8px;
}

.modal-header-icon {
    width: 18px;
    height: 18px;
    color: var(--primary-text);
}

.modal-body {
    padding: 16px 18px;
}

.modal-footer {
    padding: 12px 18px;
    border-top: 1px solid var(--border-color);
    display: flex;
    gap: 8px;
    justify-content: flex-end;
}

.detail-body {
    display: flex;
    flex-direction: column;
    gap: 10px;
    text-align: left;
}

.detail-item {
    display: flex;
    flex-direction: column;
    gap: 2px;
    border-bottom: 1px solid var(--border-color);
    padding-bottom: 6px;
}

.detail-item:last-child {
    border-bottom: none;
}

.detail-label {
    font-size: 0.7rem;
    color: var(--text-light);
    font-weight: 600;
    text-transform: uppercase;
}

.detail-value {
    font-size: 0.85rem;
    color: var(--text-main);
}

.text-bold {
    font-weight: 700;
}

.btn-edit {
    background-color: rgba(59, 130, 246, 0.15);
    color: #60a5fa;
    border: 1px solid rgba(59, 130, 246, 0.3);
    font-weight: 600;
}

.btn-edit:hover {
    background-color: rgba(59, 130, 246, 0.25);
}

.form-group {
    display: flex;
    flex-direction: column;
    gap: 4px;
    margin-bottom: 10px;
    text-align: left;
}

.form-group label {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--text-muted);
}

.form-input {
    padding: 8px 12px;
    background-color: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    color: var(--text-main);
    font-size: 0.85rem;
    outline: none;
}

.hidden {
    display: none !important;
}
