/* =========================================
   UTILITY (Sangat Penting agar tidak bertumpuk)
   ========================================= */
.hidden {
    display: none !important;
}

/* Layout & Container Absensi */
.absensi-page-container {
    display: flex;
    flex-direction: column;
    gap: 16px;
}

.absensi-content-card {
    background-color: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    padding: 20px;
}

/* Selector Imtihan Header */
.imtihan-selector-wrapper {
    display: flex;
    align-items: center;
    gap: 8px;
    background: var(--bg-card);
    padding: 6px 12px;
    border-radius: var(--radius-md);
    border: 1px solid var(--border-color);
    font-size: 0.85rem;
    color: var(--text-muted);
}

.form-input-sm {
    background: var(--bg-main);
    color: var(--text-main);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-sm);
    padding: 4px 8px;
    font-size: 0.82rem;
    outline: none;
}

/* =========================================
   STYLE DAFTAR KELAS & EMPTY STATE
   ========================================= */
.kelas-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
    gap: 16px;
}

.kelas-card-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    background-color: var(--bg-main);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    padding: 16px;
    cursor: pointer;
    transition: var(--transition);
}

.kelas-card-item:hover {
    border-color: var(--primary-border);
    transform: translateY(-2px);
}

.kelas-info {
    display: flex;
    flex-direction: column;
    gap: 4px;
}

.kelas-name {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--text-main);
}

.kelas-count {
    font-size: 0.85rem;
    color: var(--text-muted);
}

/* EMPTY STATE */
.empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 40px 20px;
    background: var(--bg-main);
    border: 1px dashed var(--border-color);
    border-radius: var(--radius-md);
}

.empty-icon-wrapper {
    width: 60px;
    height: 60px;
    background: rgba(16, 185, 129, 0.1); /* Warna hijau menyesuaikan tema absensi */
    color: #10b981;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 16px;
}

.empty-icon-wrapper i {
    width: 30px;
    height: 30px;
}

.empty-title {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--text-main);
    margin-bottom: 8px;
}

.empty-desc {
    font-size: 0.85rem;
    color: var(--text-muted);
    max-width: 350px;
    margin: 0 auto 20px auto;
    line-height: 1.4;
}

/* =========================================
   STYLE LIST SANTRI & PANDUAN ABSENSI
   ========================================= */

/* Box Panduan Absensi */
.absensi-guide-box {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    background: rgba(16, 185, 129, 0.08);
    border: 1px solid var(--primary-border);
    border-radius: var(--radius-md);
    padding: 12px 16px;
    margin-bottom: 16px;
    color: var(--text-main);
}

.guide-icon {
    color: var(--primary-text);
    display: flex;
    align-items: center;
    margin-top: 2px;
}

.guide-text p {
    font-size: 0.8rem;
    color: var(--text-muted);
    margin-top: 2px;
    line-height: 1.4;
}

/* List Santri Item Card */
.absensi-list-grid {
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-bottom: 24px;
}

.absensi-santri-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    background-color: var(--bg-main);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    padding: 12px 16px;
    cursor: pointer;
    transition: var(--transition);
}

.absensi-santri-card:hover {
    border-color: var(--primary-border);
    transform: translateX(3px);
}

.santri-card-left {
    display: flex;
    align-items: center;
    gap: 12px;
}

.santri-name {
    font-size: 0.92rem;
    font-weight: 700;
    color: var(--text-main);
}

.santri-rekap-counters {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: 4px;
}

.rekap-pill {
    font-size: 0.7rem;
    padding: 2px 6px;
    border-radius: 4px;
    background: rgba(255, 255, 255, 0.05);
    color: var(--text-light);
}

.rekap-izin b { color: #f59e0b; }
.rekap-sakit b { color: #3b82f6; }
.rekap-alpa b { color: #ef4444; }

.santri-card-right {
    display: flex;
    align-items: center;
    gap: 10px;
}

/* Status Badges */
.badge-status {
    font-size: 0.72rem;
    font-weight: 800;
    padding: 4px 10px;
    border-radius: 6px;
    letter-spacing: 0.5px;
}

.badge-status-hadir {
    background: rgba(16, 185, 129, 0.15);
    color: #10b981;
    border: 1px solid rgba(16, 185, 129, 0.3);
}

.badge-status-izin {
    background: rgba(245, 158, 11, 0.15);
    color: #f59e0b;
    border: 1px solid rgba(245, 158, 11, 0.3);
}

.badge-status-sakit {
    background: rgba(59, 130, 246, 0.15);
    color: #3b82f6;
    border: 1px solid rgba(59, 130, 246, 0.3);
}

.badge-status-alpa {
    background: rgba(239, 68, 68, 0.15);
    color: #ef4444;
    border: 1px solid rgba(239, 68, 68, 0.3);
}

/* Bottom Bar Simpan Absensi */
.absensi-bottom-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: var(--bg-main);
    border: 1px solid var(--primary-border);
    border-radius: var(--radius-md);
    padding: 14px 20px;
    position: sticky;
    bottom: 12px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.4);
}

.today-date-info {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--primary-text);
}

/* Status Option Cards inside Modal */
.target-santri-info {
    text-align: center;
    margin-bottom: 16px;
}

.target-santri-info h4 {
    font-size: 1.1rem;
    color: var(--text-main);
}

.text-date-badge {
    font-size: 0.75rem;
    color: var(--text-light);
}

.status-options-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
}

.status-option-card {
    cursor: pointer;
    position: relative;
}

.status-option-card input {
    position: absolute;
    opacity: 0;
}

.status-card-body {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    padding: 12px;
    border-radius: var(--radius-md);
    border: 1px solid var(--border-color);
    background: var(--bg-main);
    color: var(--text-muted);
    font-size: 0.8rem;
    font-weight: 600;
    transition: var(--transition);
}

.status-option-card input:checked + .status-card-body {
    border-color: var(--primary-text);
    background: rgba(16, 185, 129, 0.12);
    color: var(--text-main);
}

.option-hadir input:checked + .status-card-body { color: #10b981; border-color: #10b981; }
.option-izin input:checked + .status-card-body { color: #f59e0b; border-color: #f59e0b; }
.option-sakit input:checked + .status-card-body { color: #3b82f6; border-color: #3b82f6; }
.option-alpa input:checked + .status-card-body { color: #ef4444; border-color: #ef4444; }

@media (max-width: 640px) {
    .absensi-bottom-bar {
        flex-direction: column;
        gap: 10px;
        align-items: stretch;
        text-align: center;
    }

    .today-date-info {
        justify-content: center;
    }
}
